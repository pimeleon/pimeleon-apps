PACKAGE_NAME="dnscrypt-proxy"
PACKAGE_VERSION="2.1.15"
BUILD_TYPE="binary"

UPSTREAM_TYPE="github_release"
UPSTREAM_REPO="DNSCrypt/dnscrypt-proxy"
UPSTREAM_TAG_PREFIX=""

SUPPORTED_ARCHES="armhf arm64"

# GitHub release asset name patterns ({VERSION} is replaced at download time)
UPSTREAM_ASSET_ARMHF="dnscrypt-proxy-linux_arm-{VERSION}.tar.gz"
UPSTREAM_ASSET_ARM64="dnscrypt-proxy-linux_arm64-{VERSION}.tar.gz"

# Binary to include in the output tarball (relative to extracted upstream archive)
OUTPUT_BINARY="dnscrypt-proxy"
