PACKAGE_NAME="hostapd"
PACKAGE_VERSION="2.11"
BUILD_TYPE="source"

UPSTREAM_TYPE="http_tarball"
UPSTREAM_REPO="https://w1.fi/releases/"
SUPPORTED_ARCHES="armhf arm64"

# Hostapd build specific
CONFIG_OPTS="CONFIG_LIBNL32=y CONFIG_IEEE80211N=y CONFIG_IEEE80211AC=y CONFIG_IEEE80211AX=y"

BUILD_DEPS_ARMHF="libssl-dev:armhf libnl-3-dev:armhf libnl-genl-3-dev:armhf"
BUILD_DEPS_ARM64="libssl-dev:arm64 libnl-3-dev:arm64 libnl-genl-3-dev:arm64"

_OUTPUT_INCLUDES="usr/local/bin/hostapd usr/local/bin/hostapd_cli"
