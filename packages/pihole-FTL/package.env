PACKAGE_NAME="pihole-FTL"
PACKAGE_VERSION="v6.5"
BUILD_TYPE="source"

UPSTREAM_TYPE="github_tag"
UPSTREAM_REPO="pi-hole/FTL"
SUPPORTED_ARCHES="armhf arm64"

BUILD_DEPS_ARMHF="libgmp-dev:armhf libreadline-dev:armhf libidn11-dev:armhf nettle-dev:armhf libpcap-dev:armhf libssl-dev:armhf"
BUILD_DEPS_ARM64="libgmp-dev:arm64 libreadline-dev:arm64 libidn11-dev:arm64 nettle-dev:arm64 libpcap-dev:arm64 libssl-dev:arm64"

OUTPUT_INCLUDES="usr/bin/pihole-FTL"
