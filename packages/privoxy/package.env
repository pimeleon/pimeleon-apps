PACKAGE_NAME="privoxy"
PACKAGE_VERSION="4.1.0"
BUILD_TYPE="source"

UPSTREAM_TYPE="http_tarball"
UPSTREAM_REPO="https://www.privoxy.org/sf-download-mirror/Sources/"
SUPPORTED_ARCHES="armhf arm64"

CONFIGURE_FLAGS="--prefix=/usr/local --sysconfdir=/etc/privoxy --with-mbedtls"

BUILD_DEPS_ARMHF="zlib1g-dev:armhf libpcre2-dev:armhf libzstd-dev:armhf libmbedtls-dev:armhf autoconf"
BUILD_DEPS_ARM64="zlib1g-dev:arm64 libpcre2-dev:arm64 libzstd-dev:arm64 libmbedtls-dev:arm64 autoconf"

OUTPUT_INCLUDES="usr/local/sbin/privoxy etc/privoxy/"
