PACKAGE_NAME="tor"
PACKAGE_VERSION="0.4.8.13"
BUILD_TYPE="source"

UPSTREAM_TYPE="gitlab_tag"
UPSTREAM_REPO="tpo/core/tor"
UPSTREAM_GITLAB_HOST="gitlab.torproject.org"
UPSTREAM_TAG_PREFIX="tor-"
UPSTREAM_TAG_PATTERN="^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$"

SUPPORTED_ARCHES="armhf arm64"

CONFIGURE_FLAGS="--prefix=/usr/local --sysconfdir=/etc --localstatedir=/var --enable-systemd --disable-asciidoc --disable-manpage --disable-html-manual"

BUILD_DEPS_ARMHF="libevent-dev:armhf libssl-dev:armhf zlib1g-dev:armhf libsystemd-dev:armhf"
BUILD_DEPS_ARM64="libevent-dev:arm64 libssl-dev:arm64 zlib1g-dev:arm64 libsystemd-dev:arm64"

OUTPUT_INCLUDES="usr/local/bin/tor usr/local/bin/tor-gencert"
