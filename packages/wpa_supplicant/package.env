PACKAGE_NAME="wpa_supplicant"
PACKAGE_VERSION="2.11"
BUILD_TYPE="source"

UPSTREAM_TYPE="http_tarball"
UPSTREAM_REPO="https://w1.fi/releases/"
SUPPORTED_ARCHES="armhf arm64"

# wpa_supplicant specific
CONFIG_OPTS="CONFIG_LIBNL32=y CONFIG_CTRL_IFACE=y CONFIG_BACKEND=file"

BUILD_DEPS_ARMHF="libssl-dev:armhf libnl-3-dev:armhf libnl-genl-3-dev:armhf libnl-route-3-dev:armhf libdbus-1-dev:armhf"
BUILD_DEPS_ARM64="libssl-dev:arm64 libnl-3-dev:arm64 libnl-genl-3-dev:arm64 libnl-route-3-dev:arm64 libdbus-1-dev:arm64"

_OUTPUT_INCLUDES="usr/local/sbin/wpa_supplicant usr/local/bin/wpa_cli usr/local/bin/wpa_passphrase"
